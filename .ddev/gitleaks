#!/bin/bash

## Description: Run gitleaks secret scanner
## Usage: gitleaks [flags]
## Example: "ddev gitleaks" or "ddev gitleaks detect --verbose"
## Flags: [{"Name":"detect","Usage":"scan repository for secrets"},{"Name":"--verbose,-v","Usage":"show verbose output"},{"Name":"--no-banner","Usage":"suppress banner"},{"Name":"--help,-h","Usage":"show help"}]

# Check if gitleaks is installed
if ! command -v gitleaks &> /dev/null; then
    echo "❌ Gitleaks not found in DDEV container."
    echo "Please rebuild the web container:"
    echo ""
    echo "    ddev restart"
    echo ""
    exit 1
fi

# Default to detect if no command given
if [ $# -eq 0 ]; then
   echo "Starting gitleaks scan, please wait ..."
   exec gitleaks dir --verbose --no-banner --redact=50
else
    exec gitleaks "$@"
fi
